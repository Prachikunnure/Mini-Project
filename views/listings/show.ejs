<% layout("/layouts/boilerPlate") %>
<div class="row mt-3">
    <div class="col-8 offset-3">
        <h3><b><%= listing.title %></b></h3>
    </div>
   
    <div class="card col-8 offset-3 show-card listing-card">
        <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="Listing Image">
        <div class="card-body">
            <p class="card-text"><i>Owned By:<%= listing.owner.username %></i></p>
             <ul> 
            <li><p> <%= listing.description %></p></li>
              <li><p> &#8377;<%= listing.price.toLocaleString("en-In") %></p></li>
              <li><p> <%= listing.location %></p></li> 
               <li> <p><%= listing.country %></p></li>
            </ul>  
        </div>
    </div>
      <% if(currentuser && listing.owner._id.equals(currentuser._id)){ %>
        <div class="btns">
            <a href="/listing/<%= listing._id %>/edit" class="btn btn-dark edit-btn col-1 offset-3">Edit</a>
            <form method="POST" action="/listing/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-dark offset-5">Delete</button>
            </form>
      <% } %>
        </div>
  <br><br>


       
     <div class="col-8 offset-3 mb-3"> 
        <% if(currentuser && !listing.owner._id.equals(currentuser._id)){ %>
            <div class="d-flex justify-content-end gap-2 mb-4">
                <a href="/bookings" class="btn btn-outline-dark">My Bookings</a>
                <a href="/bookings/new/<%= listing._id %>" class="btn btn-success">Book Now</a>
            </div>
        <% } else if(currentuser) { %>
            <div class="d-flex justify-content-end mb-4">
                <a href="/bookings" class="btn btn-outline-dark">My Bookings</a>
            </div>
        <% } %>

        <% if(currentuser){ %>
       <h4>Leave the Review</h4>
        <form method="POST" action="/listing/<%= listing.id %>/reviews" novalidate class="needs-validation">
            <div class="mt-3 mb-3">
                
                <fieldset class="starability-slot">
                    <legend>First rating:</legend>
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>
            
            <div class="mt-3 mb-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                <div class="invalid-feedback">Please submit a valid comment for the review</div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
        <% } %>
        <hr />

      <%if(listing.reviews.length>0)
      {%>
        <div class="row">
            <p><b>All Reviews</b></p>
            <% for (review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-3">
                <div class="card-body">
                    <h5 class="card-title">@<%=review.author.username%></h5>
                   
                    <p class="starability-result card-text"
                     data-rating="<%= review.rating %>">
                    </p>
                    <p class="card-text"><%= review.comment %></p>
                   
                </div>
                <form class="mb-3" method="POST" action="/listing/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark mb-3">Delete</button>
                </form>
            </div>
            <% } %>
        </div>
        <% } %>
    </div>
    <div class="col-8 offset-3 mb-3">
        <h3> Where you'll be </h3>
        <div class="map"></div>
    </div>
    
</div>
