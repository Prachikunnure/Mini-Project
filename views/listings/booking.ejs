<% layout("/layouts/boilerPlate") %>
<br>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3>Book your stay</h3>
        <p class="text-muted">Complete the details below to reserve this listing.</p>

        <div class="card listing-card mb-4">
            <div class="row g-0">
                <div class="col-md-4">
                    <img src="<%= listing.image.url %>" class="img-fluid rounded-start h-100 object-fit-cover" alt="<%= listing.title %>" style="min-height: 12rem;">
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title"><b><%= listing.title %></b></h5>
                        <p class="card-text mb-1"><%= listing.location %>, <%= listing.country %></p>
                        <p class="card-text">
                            <b>&#8377;<%= listing.price.toLocaleString("en-IN") %></b> / night
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <form method="POST" action="/bookings/<%= listing._id %>" novalidate class="needs-validation" id="bookingForm">
            <div class="row">
                <div class="mb-3 col-sm-6">
                    <label for="checkIn" class="form-label">Check-in</label>
                    <input type="date" name="booking[checkIn]" id="checkIn" class="form-control" required>
                    <div class="invalid-feedback">Please select a check-in date</div>
                </div>
                <div class="mb-3 col-sm-6">
                    <label for="checkOut" class="form-label">Check-out</label>
                    <input type="date" name="booking[checkOut]" id="checkOut" class="form-control" required>
                    <div class="invalid-feedback">Please select a check-out date after check-in</div>
                </div>
            </div>

            <div class="mb-3">
                <label for="guests" class="form-label">Guests</label>
                <input type="number" name="booking[guests]" id="guests" min="1" value="1" class="form-control" required>
                <div class="invalid-feedback">Please enter at least 1 guest</div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <p class="mb-1"><span id="nightsCount">0</span> night(s)</p>
                    <p class="mb-0">
                        Estimated total:
                        <b>&#8377;<span id="totalPrice">0</span></b>
                    </p>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Confirm Booking</button>
                <a href="/listing/<%= listing._id %>" class="btn btn-outline-secondary">Cancel</a>
            </div>
            <br><br>
        </form>
    </div>
</div>

<script>
    const pricePerNight = <%= listing.price %>;
    const checkInInput = document.getElementById("checkIn");
    const checkOutInput = document.getElementById("checkOut");
    const nightsCountEl = document.getElementById("nightsCount");
    const totalPriceEl = document.getElementById("totalPrice");
    const bookingForm = document.getElementById("bookingForm");

    const today = new Date();
    const todayStr = today.toISOString().split("T")[0];
    checkInInput.min = todayStr;
    checkOutInput.min = todayStr;

    function updatePriceEstimate() {
        if (!checkInInput.value || !checkOutInput.value) {
            nightsCountEl.textContent = "0";
            totalPriceEl.textContent = "0";
            return;
        }

        const checkIn = new Date(checkInInput.value);
        const checkOut = new Date(checkOutInput.value);
        const nights = Math.round((checkOut - checkIn) / (1000 * 60 * 60 * 24));

        if (nights > 0) {
            nightsCountEl.textContent = nights;
            totalPriceEl.textContent = (pricePerNight * nights).toLocaleString("en-IN");
            checkOutInput.setCustomValidity("");
        } else {
            nightsCountEl.textContent = "0";
            totalPriceEl.textContent = "0";
            checkOutInput.setCustomValidity("Check-out must be after check-in");
        }
    }

    checkInInput.addEventListener("change", () => {
        checkOutInput.min = checkInInput.value || todayStr;
        if (checkOutInput.value && checkOutInput.value <= checkInInput.value) {
            checkOutInput.value = "";
        }
        updatePriceEstimate();
    });

    checkOutInput.addEventListener("change", updatePriceEstimate);
</script>
