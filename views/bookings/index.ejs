<% layout("/layouts/boilerPlate") %>
<br>
<div class="row mt-3">
    <div class="col-10 offset-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3>My Bookings</h3>
                <p class="text-muted mb-0">View and manage your upcoming and past reservations.</p>
            </div>
            <a href="/listing" class="btn btn-outline-dark">Explore Listings</a>
        </div>

        <% if (bookings.length === 0) { %>
            <div class="card listing-card text-center py-5">
                <div class="card-body">
                    <i class="fa-solid fa-calendar-xmark fa-2x mb-3 text-muted"></i>
                    <h5>No bookings yet</h5>
                    <p class="text-muted">When you book a stay, it will appear here.</p>
                    <a href="/listing" class="btn btn-dark">Browse Listings</a>
                </div>
            </div>
        <% } else { %>
            <div class="row row-cols-lg-2 row-cols-md-1 g-4">
                <% for (let booking of bookings) { %>
                    <div class="col">
                        <div class="card listing-card h-100">
                            <% if (booking.listing) { %>
                                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="<%= booking.listing.title %>" style="height: 12rem; object-fit: cover;">
                            <% } %>
                            <div class="card-body">
                                <% if (booking.listing) { %>
                                    <h5 class="card-title"><b><%= booking.listing.title %></b></h5>
                                    <p class="card-text text-muted mb-2">
                                        <%= booking.listing.location %>, <%= booking.listing.country %>
                                    </p>
                                    <a href="/listing/<%= booking.listing._id %>" class="btn btn-sm btn-outline-dark mb-3">View Listing</a>
                                <% } else { %>
                                    <h5 class="card-title text-muted">Listing unavailable</h5>
                                <% } %>

                                <ul class="list-unstyled mb-3">
                                    <li><b>Check-in:</b> <%= booking.checkInDate.toLocaleDateString("en-IN") %></li>
                                    <li><b>Check-out:</b> <%= booking.checkOutDate.toLocaleDateString("en-IN") %></li>
                                    <li><b>Guests:</b> <%= booking.guests %></li>
                                    <li><b>Total:</b> &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></li>
                                    <li><b>Booked on:</b> <%= booking.createdAt.toLocaleDateString("en-IN") %></li>
                                </ul>

                                <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE"
                                    onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                    <button type="submit" class="btn btn-dark">Cancel Booking</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
        <br><br>
    </div>
</div>
